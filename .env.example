# How often the poller hits Open-Meteo, in seconds. Open-Meteo updates once
# per hour, so polling more frequently just gives us a faster reaction time
# to new readings (dedup ensures no duplicate rows).
POLL_INTERVAL_SECONDS=300

# Max retries per city per poll cycle before giving up until the next cycle.
POLL_MAX_RETRIES=3

# Base seconds for exponential backoff between retries (1, 2, 4 ...).
POLL_RETRY_BACKOFF=1.0

# Where the SQLite DB lives. In Docker this points at the mounted volume so
# data survives container restarts.
DB_PATH=/data/weather.db

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
